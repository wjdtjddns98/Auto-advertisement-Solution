# ── 시크릿 / 환경설정 — 이미지에 절대 포함 금지 ──────────────────────────────
.env
.env.*
!.env.example
secrets/

# ── 가상환경 및 빌드 산출물 ───────────────────────────────────────────────────
.venv/
__pycache__/
*.pyc
*.pyo
*.pyd
*.egg-info/
dist/
build/
*.whl

# ── 개발 도구 ─────────────────────────────────────────────────────────────────
.git/
.gitignore
.github/
.claude/
.omc/

# ── 테스트 (이미지 크기 절감 — 컨테이너에서 테스트 불필요) ─────────────────────
tests/
conftest.py

# ── IDE / OS 찌꺼기 ───────────────────────────────────────────────────────────
.vscode/
.idea/
*.DS_Store
Thumbs.db

# ── 문서 (런타임 불필요) ─────────────────────────────────────────────────────
docs/
*.md
!README.md

# ── 스크립트 (개발 편의용) ────────────────────────────────────────────────────
scripts/
demo_local.py

# ── 데이터 디렉터리 (볼륨으로 마운트하므로 이미지에 포함 불필요) ─────────────────
data/

# ── assets: mascot.png 는 파이프라인에서 사용하므로 명시적 포함 ──────────────
# !assets/ 전체를 포함 (mascot.png 포함)
# 아래 규칙이 없으면 *.md 제외 규칙에 의해 assets/README.md 등이 제외될 수 있음
!assets/
