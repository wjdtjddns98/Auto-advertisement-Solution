# ===== 공통 =====
NUTTI_ENV=dev                   # dev | staging | prod
NUTTI_LOG_LEVEL=INFO
NUTTI_DRY_RUN=true              # true면 실제 외부 API 호출 없이 시뮬레이션으로 동작

# ===== 1단계: 대본 생성 (Claude) =====
ANTHROPIC_API_KEY=
NUTTI_SCRIPT_MODEL=claude-opus-4-8

# ===== 2단계: 영상 생성 =====
HEDRA_API_KEY=                  # Hedra Character-3 (캐릭터 립싱크 영상)
HEDRA_CHARACTER_ID=             # Hedra Elements에 저장한 마스코트 ID
SEEDANCE_API_KEY=               # Seedance 2.0 (배경 씬)
KLING_API_KEY=                  # Kling 3.0 (고화질 씬, 선택)
ELEVENLABS_API_KEY=             # 목소리 클로닝
ELEVENLABS_VOICE_ID=
ASSEMBLYAI_API_KEY=             # 자막 자동 삽입

# ===== 저장소: Google Sheets =====
GOOGLE_SHEETS_ID=
GOOGLE_SERVICE_ACCOUNT_JSON=    # 서비스 계정 JSON 파일 경로

# ===== 검수: 텔레그램 / 디스코드 =====
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
DISCORD_WEBHOOK_URL=

# ===== 4단계: 업로드 =====
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REFRESH_TOKEN=
INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_ACCOUNT_ID=

# ===== 간식계산기 (영상 설명란 고정 링크) =====
NUTTI_CALCULATOR_URL=https://wjdtjddns98.github.io/Nutti-Calculator/
