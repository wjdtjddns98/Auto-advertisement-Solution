# ===== 공통 =====
NUTTI_ENV=dev                   # dev | staging | prod
NUTTI_LOG_LEVEL=INFO
NUTTI_DRY_RUN=true              # true면 실제 외부 API 호출 없이 시뮬레이션으로 동작

# ===== 1단계: 대본 생성 (Claude) =====
ANTHROPIC_API_KEY=
NUTTI_SCRIPT_MODEL=claude-opus-4-8

# ===== 2단계: 영상 생성 (fal.ai FLUX.1 Kontext 프레임 → fal.ai Veo 3.1) =====
# FAL_KEY 하나로 시작 프레임(Kontext)·영상(Veo) 모두 처리. fal.ai 대시보드에서 발급.
FAL_KEY=                        # fal.ai API 키
NUTTI_MASCOT_IMAGE=             # 마스코트 레퍼런스 이미지 경로(없으면 텍스트 프롬프트만)
NUTTI_MEDIA_DIR=data/media      # 프레임/영상 로컬 저장 디렉터리

# ----- 영상 백엔드 (veo_fal 단일) -----
# fal.ai Veo 3.1 image-to-video, 네이티브 한국어 음성 + 종량제.
NUTTI_VIDEO_BACKEND=veo_fal
NUTTI_VEO_FAL_MODEL=fal-ai/veo3.1/lite/image-to-video   # lite(저비용) | fast | standard
NUTTI_VEO_FAL_POLL_INTERVAL_SEC=10.0
NUTTI_VEO_FAL_TIMEOUT_SEC=600.0
NUTTI_VEO_FAL_RESOLUTION=720p   # 720p(기본·저비용) | 1080p

# ----- fal.ai FLUX.1 Kontext 시작 프레임 -----
NUTTI_KONTEXT_MODEL=fal-ai/flux-pro/kontext
NUTTI_KONTEXT_POLL_INTERVAL_SEC=3.0
NUTTI_KONTEXT_TIMEOUT_SEC=120.0

# ===== 저장소: Google Sheets =====
GOOGLE_SHEETS_ID=
GOOGLE_SERVICE_ACCOUNT_JSON=    # 서비스 계정 JSON 파일 경로

# ===== 검수: 텔레그램 / 디스코드 =====
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
DISCORD_WEBHOOK_URL=
NUTTI_REVIEW_TIMEOUT_SEC=3600        # 검수 버튼 대기 최대 시간(초)
NUTTI_REVIEW_POLL_INTERVAL_SEC=3.0   # 텔레그램 폴링 간격(초)
NUTTI_REVIEW_STORE_PATH=data/reviews.json  # 검수 상태 영속 파일

# ===== 4단계: 업로드 =====
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REFRESH_TOKEN=
INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_ACCOUNT_ID=

# ===== 간식계산기 (영상 설명란 고정 링크) =====
NUTTI_CALCULATOR_URL=https://wjdtjddns98.github.io/Nutti-Calculator/
