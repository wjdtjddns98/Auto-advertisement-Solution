# ===== 공통 =====
NUTTI_ENV=dev                   # dev | staging | prod
NUTTI_LOG_LEVEL=INFO
NUTTI_DRY_RUN=true              # true면 실제 외부 API 호출 없이 시뮬레이션으로 동작

# ===== 1단계: 대본 생성 (Claude) =====
ANTHROPIC_API_KEY=
NUTTI_SCRIPT_MODEL=claude-opus-4-8

# ===== 2단계: 영상 생성 (Gemini 이미지 → Veo 3.1) =====
GEMINI_API_KEY=                 # Gemini/Veo API 키
NUTTI_GEMINI_IMAGE_MODEL=gemini-2.5-flash-preview-05-20
NUTTI_VEO_MODEL=veo-3.1-lite-generate-preview
NUTTI_MASCOT_IMAGE=             # 마스코트 레퍼런스 이미지 경로(없으면 텍스트 프롬프트만)
NUTTI_MEDIA_DIR=data/media     # 프레임/영상 로컬 저장 디렉터리
NUTTI_VEO_POLL_INTERVAL_SEC=15.0
NUTTI_VEO_TIMEOUT_SEC=600.0

# ----- 영상 백엔드 선택 (veo | kling) -----
# veo   = 네이티브 한국어 음성(기본).
# kling = 무음 영상 + 한국어 TTS 보이스오버(립싱크 포기).
NUTTI_VIDEO_BACKEND=veo
# kling 백엔드용 (fal.ai). FAL_KEY는 fal.ai 대시보드에서 발급. TTS는 위 GEMINI_API_KEY 재사용.
FAL_KEY=                        # fal.ai API 키 (kling 백엔드 사용 시)
NUTTI_KLING_MODEL=fal-ai/kling-video/v2.1/standard/image-to-video
NUTTI_KLING_POLL_INTERVAL_SEC=10.0
NUTTI_KLING_TIMEOUT_SEC=600.0
NUTTI_TTS_MODEL=gemini-2.5-flash-preview-tts
NUTTI_TTS_VOICE=Kore            # Gemini 사전구성 음성(한국어 발화 지원)

# ----- ElevenLabs TTS (아이 목소리 한국어 음성) -----
# 공개 계약: ElevenLabsTtsClient.synthesize(text) -> (audio_path: str, duration_sec: float)
# api.elevenlabs.io 전용 키 — CDN 등 타 호스트에 절대 첨부 금지.
ELEVENLABS_API_KEY=             # ElevenLabs 대시보드에서 발급
NUTTI_ELEVENLABS_MODEL=eleven_multilingual_v2   # 한국어 포함 29개 언어 지원
# 귀여운 아이 목소리 프리메이드 프리셋 voice_id.
# Rachel(21m00Tcm4TlvDq8ikWAM): ElevenLabs 공식 프리메이드, eleven_multilingual_v2에서 한국어 안정.
NUTTI_ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM

# ----- Kling LipSync 후처리 -----
# true면 무음 Kling 클립 + TTS 음성을 fal.ai LipSync로 합성(마스코트 입 동기화).
# false(기본)면 기존 보이스오버(mux) 동작 그대로 유지.
NUTTI_KLING_LIPSYNC=false
# LipSync TTS 소스: gemini(기본, GEMINI_API_KEY 재사용) | elevenlabs(아이 목소리, ELEVENLABS_API_KEY 필요)
NUTTI_KLING_TTS=gemini
# fal.ai Kling LipSync 모델 경로 (변경 불요 시 기본값 유지)
NUTTI_KLING_LIPSYNC_MODEL=fal-ai/kling-video/lipsync/audio-to-video

# ===== 저장소: Google Sheets =====
GOOGLE_SHEETS_ID=
GOOGLE_SERVICE_ACCOUNT_JSON=    # 서비스 계정 JSON 파일 경로

# ===== 검수: 텔레그램 / 디스코드 =====
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
DISCORD_WEBHOOK_URL=
NUTTI_REVIEW_TIMEOUT_SEC=3600        # 검수 버튼 대기 최대 시간(초)
NUTTI_REVIEW_POLL_INTERVAL_SEC=3.0   # 텔레그램 폴링 간격(초)
NUTTI_REVIEW_STORE_PATH=data/reviews.json  # 검수 상태 영속 파일

# ===== 4단계: 업로드 =====
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REFRESH_TOKEN=
INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_ACCOUNT_ID=

# ===== 간식계산기 (영상 설명란 고정 링크) =====
NUTTI_CALCULATOR_URL=https://wjdtjddns98.github.io/Nutti-Calculator/
